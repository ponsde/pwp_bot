# ============================================================================
# 财报智能问数助手 —— 自己的 LLM / embedding / VLM
# ============================================================================
# 主 LLM（Text2SQL、意图分类、回答生成）
LLM_API_KEY={your-llm-api-key}
LLM_API_BASE={your-llm-api-base}
LLM_MODEL={your-llm-model}
LLM_TIMEOUT=60

# 主 embedding（预留；目前 RAG 走 OpenViking，这里暂未使用）
EMBEDDING_API_KEY={your-embedding-api-key}
EMBEDDING_API_BASE={your-embedding-api-base}
EMBEDDING_MODEL={your-embedding-model}

# 主 VLM（预留；将来用于直读 PDF 扫描页 / 图表）
VLM_API_KEY={your-vlm-api-key}
VLM_API_BASE={your-vlm-api-base}
VLM_MODEL={your-vlm-model}

# ============================================================================
# OpenViking —— 研报 RAG 专用，独立一套
# ============================================================================
# OV embedding（必填，RAG 检索走这个）
OV_EMBEDDING_API_KEY={your-ov-embedding-api-key}
OV_EMBEDDING_API_BASE={your-ov-embedding-api-base}
OV_EMBEDDING_MODEL={your-ov-embedding-model}
OV_EMBEDDING_DIMENSION=1024

# OV LLM（OV 0.3.x 在 ov.conf 里字段名叫 vlm，但实际承担 L0/L1 摘要生成
# 等 LLM 职责。想让 OV 做自动摘要就必填；只做向量检索可留空）
OV_LLM_API_KEY={your-ov-llm-api-key}
OV_LLM_API_BASE={your-ov-llm-api-base}
OV_LLM_MODEL={your-ov-llm-model}

# ============================================================================
# 其他
# ============================================================================
SQLITE_DB_PATH=data/db/finance.db
