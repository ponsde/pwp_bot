# ── Data (large; grader can regenerate via pipeline/index scripts) ──
# Default: ignore everything under data/, then unignore:
#  - the populated SQLite DB (~663KB, needed to run the Web UI without redoing ETL)
#  - the official xlsx metadata (公司列表 / schema / 问题汇总 / 研报信息)
# The 1725 competition PDFs themselves are NOT in repo.
/data/*
!/data/db/
!/data/sample/
!/data/audit/
/data/db/*
!/data/db/finance.db
!/data/db/.gitkeep
/data/sample/*
!/data/sample/示例数据/
/data/sample/示例数据/*
!/data/sample/示例数据/附件1*.xlsx
!/data/sample/示例数据/附件3*.xlsx
!/data/sample/示例数据/附件4*.xlsx
!/data/sample/示例数据/附件6*.xlsx
!/data/sample/示例数据/附件2：财务报告/
!/data/sample/示例数据/附件5：研报数据/
/data/sample/示例数据/附件2：财务报告/*
/data/sample/示例数据/附件5：研报数据/*
!/data/sample/示例数据/附件5：研报数据/*.xlsx

